# ─── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings → API → service_role (DO NOT prefix NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin allowlist ───────────────────────────────────────────────────────
# Comma-separated emails granted /admin access. First sign-in auto-promotes
# the user's profiles.role to 'attorney' so RLS lets them read intakes.
ADMIN_EMAILS=

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# `stripe listen --forward-to localhost:3001/api/stripe/webhook` prints this
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (email) ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="Mongolstay <intake@mongolstay.com>"
INTAKE_TO=intake@mongolstay.com

# ─── Cloudflare Turnstile ──────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Manual payment instructions ───────────────────────────────────────────
NEXT_PUBLIC_ZELLE_EMAIL=pay@mongolstay.com
NEXT_PUBLIC_ZELLE_NAME="Mongolstay PLLC"
NEXT_PUBLIC_OFFICE_ADDRESS="350 5th Avenue, Suite 4810, New York, NY 10118"
